services:
  backend:
    image: 921829859547.dkr.ecr.ca-central-1.amazonaws.com/alberta-aqi-backend:latest
    ports:
      - "5223:8080"
    environment:
      POSTGRES_CONNECTION: Host=alberta-aqi-db.cby6k8q0mhnk.ca-central-1.rds.amazonaws.com;Port=5432;Database=alberta_aqi;Username=aqi_user;Password=${RDS_PASSWORD};SSL Mode=Require;Trust Server Certificate=true
      OPENAQ_API_KEY: ${OPENAQ_API_KEY}
      ASPNETCORE_ENVIRONMENT: Production

  frontend:
    image: 921829859547.dkr.ecr.ca-central-1.amazonaws.com/alberta-aqi-frontend:latest
    ports:
      - "80:80"
    depends_on:
      - backend